
# Netlify headers — Sankadiokro Manager
# Force le rechargement réseau pour les fichiers JS Flutter (jamais en cache HTTP)

# main.dart.js — jamais en cache (c'est le bundle Flutter complet)
/main.dart.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# flutter_bootstrap.js
/flutter_bootstrap.js
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# flutter.js
/flutter.js
  Cache-Control: no-cache, no-store, must-revalidate

# index.html — jamais en cache
/index.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Assets Flutter (fingerprinted) — mise en cache longue durée OK
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Icônes et manifeste
/icons/*
  Cache-Control: public, max-age=86400
/manifest.json
  Cache-Control: no-cache
